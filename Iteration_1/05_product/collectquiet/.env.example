VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only (Vercel / worker) — never prefix with VITE_
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=

# Phase 8 — controlled rollout (safe defaults: off / dry-run / deny allowlist)
# COLLECTION_AUTOMATION_ENABLED=false
# COLLECTION_AUTOMATION_DRY_RUN=true
# COLLECTION_EMAIL_SENDING_ENABLED=false
# COLLECTION_REPLY_DETECTION_ENABLED=false
# COLLECTION_PAYMENT_WEBHOOK_ENABLED=false
# COLLECTION_AUTOMATION_ALLOWLIST=
# COLLECTION_OUTBOUND_RECIPIENT_ALLOWLIST=
# COLLECTION_PAYMENT_WEBHOOK_SECRET=
# COLLECTION_WORKER_BATCH_SIZE=25
# COLLECTION_CLAIM_TTL_SECONDS=300
# COLLECTION_MAX_ATTEMPTS=3
# COLLECTION_BASE_BACKOFF_SECONDS=60

# Phase 4 — outbound email (Resend, provider-domain MVP)
# COLLECTION_EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# COLLECTION_EMAIL_FROM=reminders@collectquiet.app
# COLLECTION_INBOUND_DOMAIN=reply.collectquiet.app
# COLLECTION_DEFAULT_SENDER_NAME=Freelancer
# COLLECTION_DEFAULT_BUSINESS_NAME=
# COLLECTION_USE_RECORDING_SENDER=false

# Phase 5 — inbound replies (Resend inbound webhook)
# Point Resend inbound/received webhooks at /api/webhooks/resend-inbound
# RESEND_WEBHOOK_SECRET covers both delivery + inbound Svix verify
